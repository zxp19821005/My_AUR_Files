# Maintainer: Yahya Toubali <me@yahyatoubali.me>
pkgname=trae-bin
_pkgname=Trae
pkgver=2.3.49027
pkgrel=99
pkgdesc="AI-powered IDE by ByteDance - The Real AI Engine for code development"
arch=('x86_64')
url="https://trae.ai"
license=('MIT')
provides=("${pkgname%-bin}")
conflicts=("${pkgname%-bin}")
depends=(
    'gtk3'
    'nss'
    'alsa-lib'
    'libxkbcommon'
    'python-importlib-metadata'
    'python-fonttools'
    'perl'
    'libxkbfile'
    'webkit2gtk-4.1'
    'libsecret'
    'zeromq'
    'python-packaging'
    'python-typing_extensions'
    'python'
	'nodejs'
)
optdepends=(
    'libvulkan: Vulkan support'
)
source=("${pkgname%-bin}.deb::https://lf-cdn.trae.ai/obj/trae-ai-us/pkg/app/releases/stable/${pkgver}/linux/${_pkgname}-linux-x64.deb")
sha256sums=('759d2f9894e8f83ebe5ca116bfa5db613c8abc55f682decfb517c4cac81841a1')
prepare() {
    bsdtar -xf "${srcdir}/data."*
}
package() {
    cp -r "${srcdir}/usr" "${pkgdir}/"
    install -Dm755 -d "${pkgdir}/usr/bin"
    ln -sf "/usr/share/${pkgname%-bin}/bin/${pkgname%-bin}" "${pkgdir}/usr/bin/${pkgname%-bin}"
    if [ -f "${pkgdir}/usr/share/${pkgname%-bin}/resources/app/LICENSE.txt" ]; then
        install -Dm644 "$pkgdir/usr/share/${pkgname%-bin}/resources/app/LICENSE.txt" -t "${pkgdir}/usr/share/licenses/${pkgname}"
    fi
}
