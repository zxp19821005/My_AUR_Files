pkgname=trae-cn-bin
_pkgname=Trae_CN
pkgver=2.3.27641
pkgrel=1
pkgdesc="TRAE CN 桌面客户端（预编译二进制包）"
arch=('x86_64')
url="https://trae.ai/"
license=('LicenseRef-custom')
provides=("${pkgname%-bin}")
conflicts=("${pkgname%-bin}")
depends=(
  'gtk3'
  'nss'
  'libxkbfile'
  'libsecret'
  'alsa-lib'
  'libx11'
  'libxcb'
  'libxcomposite'
  'libxdamage'
  'libxrandr'
  'pango'
  'cairo'
  'at-spi2-core'
  'glib2'
  'expat'
  'nspr'
  'dbus'
  'libxkbcommon'
  'mesa'
  'python'
  'python-fonttools'
  'python-importlib-metadata'
  'python-typing_extensions'
  'python-packaging'
  'webkit2gtk-4.1'
)
makedepends=(
  'librsvg'
)
optdepends=(
  'vulkan-icd-loader: 启用 Vulkan 加速'
)
noextract=("${pkgname%-bin}-${pkgver}.tar.gz")
options=(
  '!strip'
  '!emptydirs'
)
source=(
  "${pkgname%-bin}-${pkgver}.tar.gz::https://lf-cdn.trae.com.cn/obj/trae-com-cn/pkg/app/releases/stable/${pkgver}/linux/${_pkgname}-linux-x64.tar.gz"
  "${pkgname%-bin}.desktop"
  "${pkgname%-bin}-url-handler.desktop"
)
sha256sums=('3cc8e9133af71fcbe0a703741bd5810cb837d97b7642d33f2e76ed2b74f86f3b'
            'a4eb998c69c9f737ebe3d017a6ea715818775e5029705acd342cd123b3b40418'
            '6d29568ce035b9653282442a5dad82d725bda03fb304f8d8241dd81a886a859d')
prepare() {
  [ -d "${srcdir}/usr" ] && rm -rf "${srcdir}/usr"
  install -Dm755 -d "${srcdir}/usr/share/${pkgname%-bin}"
  bsdtar -xf "${srcdir}/${pkgname%-bin}-${pkgver}.tar.gz" -C "${srcdir}/usr/share/${pkgname%-bin}"
}
package() {
  # 复制文件
  cp -r "${srcdir}/usr" "${pkgdir}/"
  # 确保关键入口具备可执行权限
  chmod 755 "${pkgdir}/usr/share/${pkgname%-bin}/${pkgname%-bin}"
  if [[ -f "${pkgdir}/usr/share/${pkgname%-bin}/bin/${pkgname%-bin}" ]]; then
    chmod 755 "${pkgdir}/usr/share/${pkgname%-bin}/bin/${pkgname%-bin}"
  fi
  # Electron chrome-sandbox 兼容
  if [[ -f "${pkgdir}/usr/share/${pkgname%-bin}/chrome-sandbox" ]]; then
    chmod 4755 "${pkgdir}/usr/share/${pkgname%-bin}/chrome-sandbox"
  fi
  install -Dm644 "${srcdir}/${pkgname%-bin}"*.desktop -t "${pkgdir}/usr/share/applications"
  install -Dm644 "${srcdir}/usr/share/${pkgname%-bin}/resources/app/resources/linux/code.png" "${pkgdir}/usr/share/pixmaps/${pkgname%-bin}.png"
  install -Dm644 "${srcdir}/usr/share/${pkgname%-bin}/resources/completions/bash/${pkgname%-bin}" -t "${pkgdir}/usr/share/bash-completion/completions"
  install -Dm644 "${srcdir}/usr/share/${pkgname%-bin}/resources/completions/zsh/_${pkgname%-bin}" -t "${pkgdir}/usr/share/zsh/vendor-completions"
  install -Dm644 "${srcdir}/usr/share/${pkgname%-bin}/resources/app/LICENSE.txt" -t "${pkgdir}/usr/share/${pkgname}"
}
